# -------------------------------------------------------
# BACKEND ENVIRONMENT VARIABLES
# Never commit this file. It is in .gitignore.
# VITE_ variables do NOT belong here — those are frontend only.
# -------------------------------------------------------

PORT=5000

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@cluster.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/restaurant?retryWrites=true&w=majority

# Any long random string — used to sign JWTs
# Change this to something hard to guess before deploying
JWT_SECRET=change_this_to_a_long_random_string_before_deploying

# Password staff use to log in at /staff/login
STAFF_PASSWORD=staff1234

# Where your frontend is running
# DEV:        http://localhost:5173
# PRODUCTION: https://your-app-name.vercel.app  ← change this when deploying
FRONTEND_URL=http://localhost:5173


# -------------------------------------------------------
# DEPLOYMENT NOTES (read before going live)
# -------------------------------------------------------

# BACKEND HOSTING — Use Render.com (free tier, easiest for Express)
# Do NOT deploy Express backend directly to Vercel — Vercel is serverless
# and needs extra config for Express. Render just works out of the box.
#
# Steps on Render:
# 1. Push your code to GitHub
# 2. Go to render.com → New → Web Service
# 3. Connect your GitHub repo
# 4. Set Root Directory to: backend
# 5. Build Command: npm install
# 6. Start Command: node src/index.js
# 7. Add all these env variables in Render's "Environment" tab
#    (do NOT upload this file — type them in manually)
# 8. Copy the Render URL (e.g. https://restaurant-api.onrender.com)
#    → paste it as FRONTEND_URL below after deploying frontend

# FRONTEND HOSTING — Vercel or Netlify both work fine
# Remember to update VITE_API_URL in frontend/.env to your Render backend URL
# and add it in Vercel/Netlify's environment variables panel too

# WHAT TO CHANGE BEFORE GOING LIVE:
# 1. MONGO_URI         → already points to Atlas, no change needed
# 2. JWT_SECRET        → change to a strong random string (use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")  
# 3. STAFF_PASSWORD    → change from staff1234 to something stronger
# 4. FRONTEND_URL      → change to your actual Vercel/Netlify frontend URL